{
  "name": "video-editor-backend",
  "version": "1.0.0",
  "description": "Backend Node.js pour montage vidéo automatique avec IA locale",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "prod": "npm run build && pm2 start ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "restart": "pm2 restart ecosystem.config.js",
    "logs": "pm2 logs",
    "test": "jest"
  },
  "keywords": [
    "video",
    "ffmpeg",
    "ai",
    "ollama"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "bullmq": "^4.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "file-type": "^18.7.0",
    "firebase-admin": "^12.7.0",
    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^7.2.0",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^8.21.0",
    "pino-pretty": "^10.3.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "pm2": "^5.4.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
