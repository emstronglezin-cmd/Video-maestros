# Configuration serveur
PORT=3000
NODE_ENV=production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Stockage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# Limites freemium
FREE_DAILY_EXPORTS=2
FREE_MAX_RESOLUTION=720
PREMIUM_MAX_RESOLUTION=4096

# FFmpeg
FFMPEG_THREADS=4
FFMPEG_TIMEOUT=120000

# Firebase Admin SDK (REQUIRED)
FIREBASE_PROJECT_ID=your-project-id-here
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"xxx","private_key":"-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----\n","client_email":"xxx@xxx.iam.gserviceaccount.com","client_id":"xxx","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"xxx"}

# Sécurité
LOG_LEVEL=info
CORS_ORIGIN=https://your-domain.com
MAX_FILE_SIZE=209715200
MAX_BODY_SIZE=10485760

# Backend URL (pour configuration Flutter)
BACKEND_URL=https://your-backend-url.com
