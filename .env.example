# ========================================
# VIDEO MAESTRO - CONFIGURATION BACKEND
# ========================================

# ┌──────────────────────────────────────┐
# │ CONFIGURATION SERVEUR                │
# └──────────────────────────────────────┘
PORT=3000
NODE_ENV=production

# ┌──────────────────────────────────────┐
# │ REDIS (OPTIONNEL)                    │
# │ Si non configuré → in-memory queue   │
# └──────────────────────────────────────┘
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Sur Railway.app avec Redis Plugin, ces variables sont auto-générées
# Laissez commenté si pas de Redis - le backend fonctionne sans

# ┌──────────────────────────────────────┐
# │ OLLAMA AI (OPTIONNEL)                │
# │ Si non configuré → AI features OFF   │
# └──────────────────────────────────────┘
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b

# Laissez vide ou commenté si pas d'Ollama
# Les fonctionnalités IA seront désactivées automatiquement

# ┌──────────────────────────────────────┐
# │ STOCKAGE                             │
# └──────────────────────────────────────┘
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# ┌──────────────────────────────────────┐
# │ LIMITES FREEMIUM                     │
# └──────────────────────────────────────┘
FREE_DAILY_EXPORTS=2
FREE_MAX_RESOLUTION=720
PREMIUM_MAX_RESOLUTION=4096

# ┌──────────────────────────────────────┐
# │ FFMPEG                               │
# └──────────────────────────────────────┘
FFMPEG_THREADS=4
FFMPEG_TIMEOUT=120000

# ┌──────────────────────────────────────┐
# │ FIREBASE ADMIN SDK (OBLIGATOIRE)     │
# └──────────────────────────────────────┘
# ⚠️ CRITICAL: Ces 3 variables sont REQUISES pour l'authentification

FIREBASE_PROJECT_ID=video-maestros
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@video-maestros.iam.gserviceaccount.com
